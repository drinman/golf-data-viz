# Supabase — Required
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — Server-only (required when anonymous round saving is enabled)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Save controls
# ENABLE_ROUND_SAVE=true
# Use Cloudflare Turnstile test keys locally or in preview when anonymous save is enabled.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Vercel KV / Upstash (for distributed rate limiting)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_URL=
# RATE_LIMIT_SALT=replace-with-random-16+-char-string-required-for-prod
# Non-production falls back to a deterministic dev salt if unset/too short.

# Phase 2: Proxy SG pipeline mode (off | shadow | full). Default: off
# SG_PHASE2_MODE=off
# NEXT_PUBLIC_SG_PHASE2_MODE=off

# Analytics — Optional (fail-open, app works without these)
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Billing / Premium
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PREMIUM_PRICE_ID=price_...

# Monitoring (required in production when anonymous round saving is enabled)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_RELEASE=

# Arccos API (future)
# ARCCOS_API_KEY=
# ARCCOS_API_SECRET=

# Base URL — Used for OG image metadata. Set to your production domain.
# NEXT_PUBLIC_BASE_URL=https://golfdataviz.com
# NEXT_PUBLIC_SITE_URL=https://golfdataviz.com
