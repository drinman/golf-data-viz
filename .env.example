# Supabase — Required
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — Server-only (for admin operations, not needed for MVP)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Save controls
# ENABLE_ROUND_SAVE=true

# Vercel KV / Upstash (for distributed rate limiting)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_URL=
# RATE_LIMIT_SALT=replace-with-long-random-string-required-for-prod

# Analytics — Optional (fail-open, app works without these)
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Monitoring
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_RELEASE=

# Arccos API (future)
# ARCCOS_API_KEY=
# ARCCOS_API_SECRET=

# Base URL — Used for OG image metadata. Set to your production domain.
# NEXT_PUBLIC_BASE_URL=https://golfdataviz.com
